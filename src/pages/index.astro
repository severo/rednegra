---
import { Image } from "astro:assets";
import heroImage from "@assets/sylvain-lesage.jpeg";
import TagsList from "@components/TagsList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@lib/consts";
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  {
    heroImage && (
      <Image
        width={512}
        height={512}
        src={heroImage}
        alt="Portrait of Sylvain Lesage"
        style="width: 150px; border-radius: 50%; float: right; margin-left: 1em; margin-bottom: 1em;"
      />
    )
  }

  <header>
    <h1 style="margin-bottom: 0em;">Sylvain Lesage</h1>
    <div class="gray" style="font-size: 1.2em;">Senior frontend developer</div>
  </header>

  <p>
    👋 Hi, I'm Sylvain Lesage. I have a background in data science, data
    visualization, and web development, and I love creating interactive
    visualizations, advanced graphical tools, and <em
      >data-driven applications</em
    >.
  </p>

  <figure class="tags">
    <TagsList
      ids={[
        // "html",
        "javascript",
        "typescript",
        "react",
        "svelte",
        "vue",
        "d3",
        "threejs",
        "map",
        "svg",
        // "canvas",
        "python",
        // "r",
        // "postgresql",
        // "duckdb",
        "parquet",
      ]}
    />
    <figcaption>
      Explore my skills on the <a href="/tags/">tags page</a>.
    </figcaption>
  </figure>

  <p>
    I'm looking for a 🟢 <strong>new job</strong>. Let's talk!
  </p>

  <h2>Past works</h2>

  <p>
    Browse my <a href="/works">portfolio</a> for an overview of my past projects.
  </p>
  <p>
    See my <a href="/resume/">resume</a> (or <a
      href="https://www.linkedin.com/in/sylvain--lesage/">LinkedIn</a
    >) for more details about my experience and skills.
  </p>

  <h2>
    <a href="/blog/">Blog</a>
  </h2>

  <p>
    Read my thoughts on data visualization, software development and related
    topics on my ✎ <a href="/blog/">blog</a>.
  </p>

  <p>
    For example, you might like <a href="/blog/20260212-virtual-scroll/"
      >Virtual Scrolling for Billions of Rows — Techniques from HighTable</a
    >.
  </p>

  <h2>Contact</h2>
  <p>
    You can contact me by mail at ✉️ <a href="mailto:severo@rednegra.net"
      >severo@rednegra.net</a
    >.
  </p>
  <p>
    Find me also on <a href="https://www.linkedin.com/in/sylvain--lesage/"
      >LinkedIn</a
    >, <a href="https://github.com/severo">GitHub</a>,
    <a href="https://mastodon.social/@severo">Mastodon</a>, <a
      href="https://huggingface.co/severo">Hugging Face</a
    >,
    <a href="https://observablehq.com/@severo">Observable</a>, <a
      href="https://www.researchgate.net/profile/Sylvain_Lesage">ResearchGate</a
    >,
    <a href="https://stackoverflow.com/users/7351594/sylvain-lesage"
      >Stack Overflow</a
    >, <a href="https://www.openstreetmap.org/user/Sylvain%20Lesage"
      >OpenStreetMap</a
    >
    and <a href="https://www.malt.fr/profile/sylvainlesage">Malt</a>.
  </p>
</BaseLayout>

<style>
  .tags {
    figcaption {
      font-size: 0.9em;
      color: var(--color-gray);
      margin-top: 0.5em;
      text-align: right;
      font-style: italic;
    }
  }
</style>
