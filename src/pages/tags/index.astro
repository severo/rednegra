---
import { SITE_DESCRIPTION } from "../../consts";
import WideLayout from "../../layouts/WideLayout.astro";
import Tag from "../../components/Tag.astro";

import { getCollection } from "astro:content";
const tags = await getCollection("tags");
---

<WideLayout title="Tags — Sylvain Lesage" description={SITE_DESCRIPTION}>
  <header>
    <p>＜ <a href="/">Home</a></p>
    <h1>Tags</h1>
  </header>

  <section class="tags">
    {
      tags.map((tag) => (
        <Tag id={tag.id} collection={tag.collection} fontSize="1em" />
      ))
    }
  </section>
</WideLayout>

<style type="text/css">
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
</style>
