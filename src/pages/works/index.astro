---
import WorksGallery from "../../components/WorksGallery.astro";
import { SITE_DESCRIPTION } from "../../consts";
import WideLayout from "../../layouts/WideLayout.astro";

const padding = 64;
const gap = 10;
const figureWidth = 300;
const maxColumns = 8;
---

<WideLayout
  title={"Portfolio - Sylvain Lesage"}
  description={SITE_DESCRIPTION}
  padding={padding}
>
  <h1>Works</h1>
  <p>
    An overview of my past projects and activities. <a href="/#contact"
      >Contact me</a
    > for more information.
  </p>
  <WorksGallery
    padding={padding}
    gap={gap}
    figureWidth={figureWidth}
    maxColumns={maxColumns}
  />
</WideLayout>
