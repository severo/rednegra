---
import WorksGallery from "../../components/WorksGallery.astro";
import { SITE_DESCRIPTION } from "../../consts";
import WideLayout from "../../layouts/WideLayout.astro";

const padding = 64;
const gap = 10;
const figureWidth = 300;
const maxColumns = 8;
---

<WideLayout
  title={"Works portfolio — Sylvain Lesage"}
  description={SITE_DESCRIPTION}
  padding={padding}
>
  <header>
    <p>＜ <a href="/">Home</a></p>
    <h1>Works portfolio</h1>
  </header>
  <p>
    An overview of my past projects and activities. Part of my portfolio is also
    published on <a href="https://illisible.net/sylvain-lesage?lang=en">
      illisible.net
    </a> (look at <a href="https://illisible.net">the other profiles too</a>). <a
      href="/#contact">Contact me</a
    > for more information.
  </p>
  <p>
    ⚠️ Work in progress during April 2026. I'm trying to document past projects
    with screenshots, tags and descriptions.
  </p>

  <WorksGallery
    padding={padding}
    gap={gap}
    figureWidth={figureWidth}
    maxColumns={maxColumns}
  />
</WideLayout>
