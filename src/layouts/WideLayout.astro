---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  padding?: number;
  language?: "en" | "es-BO";
}

const { title, description, padding, language } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  language={language}
  className="wide"
  padding={padding}
>
  <slot />
</BaseLayout>
