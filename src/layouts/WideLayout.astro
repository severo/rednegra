---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  padding?: number;
}

const { title, description, padding } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style
      type="text/css"
      define:vars={{
        padding: `${padding ?? 64}px`,
      }}
    >
      .main {
        width: 100%;
        max-width: 100%;
        padding: 2rem var(--padding);
      }
    </style>
  </head>
  <body>
    <main class="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
